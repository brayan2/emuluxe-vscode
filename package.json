{
  "name": "emuluxe-vscode",
  "displayName": "Emuluxe: Mobile Simulation",
  "description": "Powerful mobile device simulation directly in VS Code and Cursor.",
  "version": "1.1.3",
  "publisher": "BrigxelSolutions",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brayan2/emuluxe-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:emuluxe.login"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "emuluxe.setup",
        "title": "Welcome to Emuluxe",
        "description": "Get started with the Emuluxe visual simulator.",
        "steps": [
          {
            "id": "login",
            "title": "Connect Your Emuluxe Account",
            "description": "Securely pair your CLI Token with your IDE.\n[Login to Emuluxe](command:emuluxe.login)",
            "media": {
              "markdown": "walkthrough/login.md"
            }
          },
          {
            "id": "start",
            "title": "Start Simulating",
            "description": "Run the command from your Command Palette and pick an HD device.\n[Start Simulation](command:emuluxe.start)",
            "media": {
              "markdown": "walkthrough/start.md"
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "emuluxe.start",
        "title": "Start Simulation",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.login",
        "title": "Login",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.stop",
        "title": "Stop Simulation",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.billing",
        "title": "Open Billing",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.device",
        "title": "Change Device",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.rotate",
        "title": "Rotate Device",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.screenshot",
        "title": "Take Screenshot",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.inspect",
        "title": "Open Inspector",
        "category": "Emuluxe"
      }
    ],
    "keybindings": [
      {
        "command": "emuluxe.start",
        "key": "cmd+alt+e",
        "mac": "cmd+alt+e",
        "win": "ctrl+alt+e"
      },
      {
        "command": "emuluxe.login",
        "key": "cmd+alt+l",
        "mac": "cmd+alt+l",
        "win": "ctrl+alt+l"
      },
      {
        "command": "emuluxe.device",
        "key": "cmd+alt+d",
        "mac": "cmd+alt+d",
        "win": "ctrl+alt+d",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.stop",
        "key": "cmd+alt+x",
        "mac": "cmd+alt+x",
        "win": "ctrl+alt+x",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.rotate",
        "key": "cmd+r",
        "mac": "cmd+r",
        "win": "ctrl+r",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.screenshot",
        "key": "cmd+s",
        "mac": "cmd+s",
        "win": "ctrl+s",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.inspect",
        "key": "cmd+i",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      }
    ],
    "configuration": {
      "title": "Emuluxe",
      "properties": {
        "emuluxe.apiUrl": {
          "type": "string",
          "default": "https://app.emuluxe.com",
          "description": "Emuluxe API URL"
        },
        "emuluxe.token": {
          "type": "string",
          "default": "",
          "description": "CLI token for authentication"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "sharp": "^0.34.5"
  },
  "files": [
    "dist",
    "images",
    "node_modules",
    "walkthrough",
    "package.json",
    "CHANGELOG.md",
    "README.md"
  ]
}
