{
  "name": "emuluxe-vscode",
  "displayName": "Emuluxe: Mobile Simulation",
  "description": "Powerful mobile device simulation directly in VS Code and Cursor.",
  "version": "1.0.0",
  "publisher": "emuluxe",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/brayan2/emuluxe-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emuluxe.start",
        "title": "Emuluxe: Start Simulation",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.login",
        "title": "Emuluxe: Login",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.stop",
        "title": "Emuluxe: Stop Simulation",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.device",
        "title": "Emuluxe: Change Device",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.rotate",
        "title": "Emuluxe: Rotate Device",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.screenshot",
        "title": "Emuluxe: Take Screenshot",
        "category": "Emuluxe"
      },
      {
        "command": "emuluxe.inspect",
        "title": "Emuluxe: Open Inspector",
        "category": "Emuluxe"
      }
    ],
    "keybindings": [
      {
        "command": "emuluxe.rotate",
        "key": "cmd+r",
        "mac": "cmd+r",
        "win": "ctrl+r",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.screenshot",
        "key": "cmd+s",
        "mac": "cmd+s",
        "win": "ctrl+s",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      },
      {
        "command": "emuluxe.inspect",
        "key": "cmd+i",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "when": "activeWebviewPanelId == 'emuluxeSim'"
      }
    ],
    "configuration": {
      "title": "Emuluxe",
      "properties": {
        "emuluxe.apiUrl": {
          "type": "string",
          "default": "https://app.emuluxe.com",
          "description": "Emuluxe API URL"
        },
        "emuluxe.token": {
          "type": "string",
          "default": "",
          "description": "CLI token for authentication"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
